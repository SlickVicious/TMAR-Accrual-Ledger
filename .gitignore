# Claude Code project settings (local dev environment, not repo config)
# Ignore everything under .claude/ by default...
.claude/*
# ...but SHARE team-usable subagents + skills so other machines (Mac) can pull them.
!.claude/agents/
!.claude/skills/
# Security-sensitive / machine-local files stay ignored on purpose:
#   .claude/settings.local.json  — permission allowlist + local machine paths
#   .claude/hooks/               — local guardrail scripts (secret-blocker, test-runner)

# Playwright MCP session snapshots (ephemeral browser tool artifacts)
.playwright-mcp/

# Runtime-generated HTML backups (vault backup, not source)
*.bak-vault

